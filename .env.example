# LLM Configuration
# Default model used for all agents (can be any LiteLLM-supported model)
DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514

# Per-agent model overrides (optional)
# NARRATOR_MODEL=anthropic/claude-sonnet-4-20250514
# ORCHESTRATOR_MODEL=anthropic/claude-sonnet-4-20250514
# COORDINATOR_MODEL=anthropic/claude-sonnet-4-20250514
# CLINICIAN_MODEL=anthropic/claude-sonnet-4-20250514
# SCRIBE_MODEL=anthropic/claude-sonnet-4-20250514

# API Keys (set the ones you need)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Output
OUTPUT_DIR=output
LOG_LEVEL=INFO
MAX_RETRIES=3
